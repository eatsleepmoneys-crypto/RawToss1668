# ============================================================
#  TigerLotto — .env.example
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
#  cp .env.example .env
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# โดเมนของคุณ (ใส่ให้ถูก — ใช้กับ CORS และ SSL)
APP_URL=https://yourdomain.com
DOMAIN=yourdomain.com

# ── Database ─────────────────────────────────────────────────
# (install.sh จะสร้างอัตโนมัติ — ไม่ต้องแก้ถ้าใช้ install.sh)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tigerlotto_db
DB_USER=tigerlotto_user
DB_PASS=YOUR_DB_PASSWORD_HERE

# ── JWT ───────────────────────────────────────────────────────
# (install.sh จะ generate อัตโนมัติ — ต้องยาวและสุ่ม)
JWT_SECRET=YOUR_SUPER_LONG_RANDOM_SECRET_HERE_MIN_48_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Upload ────────────────────────────────────────────────────
UPLOAD_DIR=/var/www/tigerlotto/uploads
MAX_FILE_SIZE=5242880

# =============================================================
#  API KEYS — ใส่เพื่อให้ฟีเจอร์เหล่านี้ทำงาน
# =============================================================

# ── 💳 Payment Gateway (2C2P) ─────────────────────────────────
# สมัคร: https://www.2c2p.com/developer
# ทดสอบฟรี ค่าธรรมเนียม ~2% ต่อรายการ
PAYMENT_2C2P_MERCHANT=
PAYMENT_2C2P_SECRET_KEY=
PAYMENT_2C2P_BASE_URL=https://pgw.2c2p.com/payment/4.1/

# ── 📱 PromptPay QR (KBank Open API) ─────────────────────────
# สมัคร: https://apiportal.kasikornbank.com
# ต้องมีบัญชีธุรกิจ KBank
KBANK_APP_ID=
KBANK_APP_SECRET=
KBANK_PROXY_ID=       # เบอร์มือถือหรือเลขประจำตัวที่ผูก PromptPay
KBANK_BASE_URL=https://openapi.kasikornbank.com

# ── 💚 TrueMoney Wallet ───────────────────────────────────────
# สมัคร: https://developer.truemoney.com
TRUEMONEY_APP_KEY=
TRUEMONEY_PARTNER_CODE=
TRUEMONEY_SECRET=
TRUEMONEY_BASE_URL=https://api.truemoney.com/wallet/v1/

# ── 📩 SMS Gateway (Infobip) ──────────────────────────────────
# สมัคร: https://www.infobip.com (FREE tier: 100 SMS/เดือน)
# เอา API Key จาก Dashboard → API Keys
INFOBIP_API_KEY=
INFOBIP_BASE_URL=https://XXXXX.api.infobip.com   # ดูใน Dashboard
INFOBIP_SENDER=TigerLotto

# ── 🔐 OTP (Telnyx) — ทางเลือกแทน Infobip ───────────────────
# สมัคร: https://telnyx.com (FREE trial $10)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=+66XXXXXXXXXX

# ── 💬 LINE Notify ────────────────────────────────────────────
# ทำใน 5 นาที ฟรี 100%:
# 1. ไป https://notify-bot.line.me/my/
# 2. กด "Generate token"
# 3. เลือก Group หรือ Chat ที่ต้องการรับแจ้งเตือน
# 4. Copy token ใส่ด้านล่าง
LINE_NOTIFY_TOKEN=

# LINE Messaging API (ถ้าต้องการ chatbot เต็มรูปแบบ)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── 🔔 Firebase FCM (Push Notification) ──────────────────────
# ทำใน 10 นาที ฟรี:
# 1. ไป https://console.firebase.google.com
# 2. สร้าง Project ใหม่
# 3. Project Settings → Service Accounts → Generate new private key
# 4. ใส่ Project ID และ path ของ JSON file
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/tigerlotto/api/firebase-adminsdk.json

# ── 🧾 SlipOK Auto Verify ─────────────────────────────────────
# ตรวจสลิปอัตโนมัติ สมัคร: https://www.slipok.com
# x-authorization API key และ Branch ID จาก Dashboard
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=

# ── 🔗 Webhook Secret ─────────────────────────────────────────
# ใช้ verify webhook จากธนาคาร
WEBHOOK_SECRET=

# =============================================================
#  ตั้งค่าเพิ่มเติม (ไม่จำเป็นต้องแก้)
# =============================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Session
SESSION_SECRET=another_random_secret_here

# Logs
LOG_LEVEL=info
LOG_DIR=/var/www/tigerlotto/logs
