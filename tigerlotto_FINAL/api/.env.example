# ─── SERVER ───────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ─── DATABASE (MySQL) ─────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tigerlotto
DB_USER=root
DB_PASS=your_db_password

# ─── JWT ──────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d
JWT_ADMIN_EXPIRE=8h

# ─── OTP / SMS (THSMS) ────────────────
SMS_API_KEY=your_sms_api_key
SMS_SENDER=TigerLotto
SMS_ENABLED=false

# ─── LINE Messaging API ───────────────
LINE_CHANNEL_TOKEN=your_line_channel_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_ENABLED=false

# ─── EMAIL (SMTP) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tigerlotto.com
SMTP_PASS=your_smtp_password
SMTP_FROM=TigerLotto <noreply@tigerlotto.com>

# ─── PROMPTPAY ────────────────────────
PROMPTPAY_NUMBER=0812345678
PROMPTPAY_NAME=บริษัท ไทเกอร์ ลอตโต้

# ─── SCB EASY API ─────────────────────
SCB_API_KEY=your_scb_api_key
SCB_API_SECRET=your_scb_api_secret
SCB_BILLER_ID=your_biller_id
SCB_ENABLED=false

# ─── UPLOAD ───────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ─── FRONTEND URL (CORS) ──────────────
FRONTEND_URL=http://localhost
ADMIN_URL=http://localhost/admin

# ─── RATE LIMITING ────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT=5

# ─── ENCRYPTION ───────────────────────
BCRYPT_ROUNDS=12
